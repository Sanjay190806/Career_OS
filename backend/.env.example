NODE_ENV=development
PORT=5000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
JWT_SECRET="replace_with_secure_random_secret"
FRONTEND_URL="http://localhost:5173"
GOOGLE_CLIENT_ID="replace_with_google_oauth_client_id"
GOOGLE_CLIENT_SECRET="replace_with_google_oauth_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"
GROQ_API_KEY="replace_with_optional_backend_only_groq_key"
GROQ_MODEL="replace_with_optional_groq_model"
OPENROUTER_API_KEY="replace_with_optional_backend_only_openrouter_key"
OPENAI_API_KEY="replace_with_optional_backend_only_openai_key"
ANTHROPIC_API_KEY="replace_with_optional_backend_only_anthropic_key"
GEMINI_API_KEY="replace_with_optional_backend_only_gemini_key"
